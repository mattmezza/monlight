# Error Tracker
ERROR_TRACKER_API_KEY=<generate-random-32-char-string>

# Log Viewer
LOG_VIEWER_API_KEY=<generate-random-32-char-string>

# Metrics Collector
METRICS_COLLECTOR_API_KEY=<generate-random-32-char-string>

# Browser Relay
BROWSER_RELAY_ADMIN_API_KEY=<generate-random-32-char-string>

# CORS origins for browser relay (comma-separated, no trailing slashes)
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Docker container names for log-viewer to monitor (comma-separated)
# CONTAINERS=my_app_prod,my_app_staging

# SMTP email alerts (optional)
SMTP_HOST=
SMTP_PORT=25
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=errors@example.com

# Alert recipients (comma-separated)
ALERT_EMAILS=admin@example.com

# Log level for all services (error, warn, info, debug). Default: info
# LOG_LEVEL=info
